# Keep the build context (and image) small, and NEVER copy secrets or local artifacts.

# Version control
.git/
.gitignore
.gitattributes

# Secrets / local env — the API key is passed at runtime, never baked into the image.
.env
.env.local

# Python caches / bytecode
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# Runtime artifact — the DB is rebuilt during the image build (data/load_db.py)
dr_mundo.db

# Local MLflow tracking store
mlflow.db
mlruns/
mlartifacts/

# Editor / OS cruft
.vscode/
.idea/
.DS_Store
